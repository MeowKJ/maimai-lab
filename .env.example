# ==============================
# Python Bot
# ==============================
MAIMAI_DEBUG=false
MAIMAI_BOT_APPID=
MAIMAI_BOT_SECRET=
MAIMAI_BOT_VERSION=3.0-modern
MAIMAI_LXNS_API_SECRET=
MAIMAI_ASSETS_URL=https://maimai.mpas.top
MAIMAI_DEFAULT_AVATAR_URL=https://q1.qlogo.cn/g?b=qq&nk=0&s=640
MAIMAI_DATABASE_PATH=./data/bot.db
MAIMAI_TEMP_DIR=./tmp

