# ============================================================
# maimai Hub — apps/web 环境变量
# 复制此文件为 .env.local 并填入值
# ============================================================

# -------------------------------------------------------
# LuoXue (落雪) API Key
# 获取地址：https://maimai.lxns.net/developer
# 推荐：服务端变量（不会暴露到浏览器）
# -------------------------------------------------------
MAIMAI_LXNS_API_KEY=

# 可选兼容：旧版客户端变量（会暴露在浏览器，不推荐）
NEXT_PUBLIC_MAIMAI_LXNS_API_KEY=

# -------------------------------------------------------
# ImageKit — 图片 CDN 缓存
# 获取地址：https://imagekit.io → 账号设置 → Developer options
# PUBLIC_KEY：  ik_public_xxxxxxxxxxxx 格式
# PRIVATE_KEY： ik_private_xxxxxxxxxxxx 格式（服务端/Edge专用，不加 NEXT_PUBLIC_）
# URL_ENDPOINT：https://ik.imagekit.io/your_id 格式
# -------------------------------------------------------
MAIMAI_IMAGEKIT_PUBLIC_KEY=
MAIMAI_IMAGEKIT_PRIVATE_KEY=
MAIMAI_IMAGEKIT_URL_ENDPOINT=

# -------------------------------------------------------
# Legacy Asset Origin（旧版素材源站，用于 prism / ongeki 资源）
# 默认值即可，除非你有自建源站
# -------------------------------------------------------
MAIMAI_LEGACY_ASSET_ORIGIN=https://maimai.mpas.top
